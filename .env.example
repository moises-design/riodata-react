# Copy this file to .env and fill in the real values.
# Never commit .env — it is listed in .gitignore.

# Supabase project credentials
# Found in: Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_<your-anon-key>

# Mapbox GL JS public token
# Found in: https://account.mapbox.com/access-tokens/
# Restrict allowed URLs in the Mapbox dashboard to prevent abuse.
VITE_MAPBOX_TOKEN=pk.eyJ1IjoiPHVzZXJuYW1lPiIsImEiOiI8aWQ+In0.<signature>

# US Census Bureau API key (free, public scope)
# Register at: https://api.census.gov/data/key_signup.html
VITE_CENSUS_API_KEY=<your-census-api-key>

# ─── Server-side secrets (Supabase Edge Function secrets — NOT in .env) ────────
# Set these with: npx supabase secrets set KEY=value
#
#   FRED_API_KEY     — FRED / St. Louis Fed  https://fred.stlouisfed.org/docs/api/api_key.html
#   EIA_API_KEY      — US Energy Information Administration  https://www.eia.gov/opendata/register.php
#   NEWS_API_KEY     — NewsAPI.org  https://newsapi.org/register
